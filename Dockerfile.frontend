FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

# Expose port
EXPOSE 3000

# Start the application (dev server for local Docker usage)
CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0", "--port", "3000"]
