APP_ENV=development
DATABASE_URL=postgresql+psycopg://dev:password@localhost:5432/reconciliation
REDIS_URL=redis://localhost:6379/0
UPLOAD_STORAGE_PATH=/app/storage/uploads
FRONTEND_APP_URL=http://localhost:3001

# API Keys
OPENAI_API_KEY=
AZURE_AI_KEY=
AZURE_AI_ENDPOINT=

# App
DEBUG=True
LOG_LEVEL=INFO
LOG_JSON=True
APP_NAME=AI Reconciliation SaaS
VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000

# Auth
JWT_SECRET_KEY=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
AUTH_BOOTSTRAP_ENABLED=false
JOB_MAX_RETRIES=3
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI Reconciliation SaaS
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000
