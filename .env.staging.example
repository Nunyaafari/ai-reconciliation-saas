APP_ENV=staging
POSTGRES_USER=staging_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=reconciliation_staging
DATABASE_URL=postgresql+psycopg://staging_user:change-me@postgres:5432/reconciliation_staging
REDIS_URL=redis://redis:6379/0
UPLOAD_STORAGE_PATH=/app/storage/uploads
FRONTEND_APP_URL=https://staging.example.com
NEXT_PUBLIC_API_URL=https://staging-api.example.com
DEBUG=False
LOG_LEVEL=INFO
LOG_JSON=True
CORS_ORIGINS=https://staging.example.com
JWT_SECRET_KEY=replace-with-long-random-secret
AUTH_BOOTSTRAP_ENABLED=false
JOB_MAX_RETRIES=3
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
AUTH_LOGIN_MAX_ATTEMPTS=12
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_PASSWORD_RESET_MAX_ATTEMPTS=6
AUTH_PASSWORD_RESET_WINDOW_SECONDS=1800
API_CPUS=2
API_MEM_LIMIT=2g
WORKER_CPUS=2
WORKER_MEM_LIMIT=2g
FRONTEND_CPUS=1
FRONTEND_MEM_LIMIT=1g
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI Reconciliation SaaS
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
OPENAI_API_KEY=
AZURE_AI_KEY=
AZURE_AI_ENDPOINT=
